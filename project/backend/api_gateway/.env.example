PORT=7000
MONGO_URI=mongodb://localhost:27017/yourdb

JWT_SECRET=replace_this_with_long_secret
JWT_EXPIRES=1h
JWT_REFRESH_EXPIRES=30d

# For sending email via Gmail SMTP (recommended: use OAuth2 or app password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password_or_oauth_token

# Or if using nodemailer's oauth2:
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REFRESH_TOKEN=...

# SMS provider (example: Twilio)
SMS_PROVIDER=twilio
TWILIO_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM=+1xxxxxx

# Optional
FRONTEND_URL=https://your-front.example (for verify links)

JWT_SECRET=dev_secret
JWT_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=your_user
EMAIL_PASS=your_pass

SMS_PROVIDER_SID=
SMS_PROVIDER_TOKEN=

# AI Configuration
# === AI MODE ===
AI_MODE=auto   # auto | rapidapi | openai | mock

# === RapidAPI (Primary) ===
RAPIDAPI_KEY=
RAPIDAPI_HOST=chatgpt-4o-mini.p.rapidapi.com

# === OpenAI (Secondary) ===
OPENAI_API_KEY=

# === Safety ===
AI_TIMEOUT_MS=6000
